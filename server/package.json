{
  "name": "farmacia-server",
  "version": "1.0.0",
  "description": "Backend del Sistema de Farmacia",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --noEmitOnError false || exit 0",
    "start": "node dist/server.js",
    "migrate": "tsx src/database/migrate.ts",
    "migrate-price-history": "tsx src/database/migrate-price-history.ts",
    "setup-env": "node setup-env.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "sqlite3": "^5.1.6",
    "express-validator": "^7.0.1",
    "pdfkit": "^0.14.0",
    "xlsx": "^0.18.5",
    "qrcode": "^1.5.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.5",
    "@types/qrcode": "^1.5.5",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0"
  }
}
